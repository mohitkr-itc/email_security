# =============================================================================
# Agentic Email Security System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- Azure Service Bus ---
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_NAME=email-analysis-queue

# --- Azure Storage ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=email-attachments

# --- Azure Identity ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Threat Intelligence API Keys ---
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
SHODAN_API_KEY=

# --- Model Paths ---
HEADER_MODEL_PATH=models/header_agent/
CONTENT_MODEL_PATH=models/content_agent/
URL_MODEL_PATH=models/url_agent/
ATTACHMENT_MODEL_PATH=models/attachment_agent/
SANDBOX_MODEL_PATH=models/sandbox_agent/
THREAT_INTEL_MODEL_PATH=models/threat_intel_agent/
USER_BEHAVIOR_MODEL_PATH=models/user_behavior_agent/

# --- Dataset Paths ---
DATASET_BASE_PATH=datasets/
PROCESSED_DATASET_PATH=datasets_processed/

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/email_security

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Logging ---
LOG_DIR=logs/
LOG_FORMAT=json
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
